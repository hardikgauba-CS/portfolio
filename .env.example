# ===========================================
# Portfolio environment variables
# ===========================================
# 1. Copy this file to .env.local:  cp .env.example .env.local
# 2. Replace placeholder values with YOUR own keys (get them from the links below).
# 3. For Vercel: add these in Project → Settings → Environment Variables.
# Do NOT commit .env.local or put real keys in this file.
# ===========================================

# ----- GitHub (contribution graph widget) -----
# Server-side token. Create at: https://github.com/settings/tokens
# Scopes: no extra scopes needed for public contribution data
GITHUB_TOKEN=

# Your GitHub username (for contribution calendar). Same as above if using only server API.
GITHUB_USERNAME=

# If using client-side GitHub fetch (lib/githubApi.ts), set this too:
# NEXT_PUBLIC_GITHUB_USERNAME=

# ----- OpenAI (AI Assistant chat widget) -----
# Create at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ----- Mapbox (map widget) -----
# Create at: https://account.mapbox.com/access-tokens/
# Use a public token (starts with pk.); allow "Public scopes" for map display
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# ----- Instagram (optional – Instagram widget) -----
# Get from Meta for Developers: https://developers.facebook.com/
# Create an app → add Instagram Basic Display → get access token and user ID
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ----- MongoDB (optional – feedback form storage) -----
# Create a free cluster at: https://www.mongodb.com/atlas
# Connection string looks like: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGO_URI=
